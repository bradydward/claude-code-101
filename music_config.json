  "dj_system": {
    "description": "Claude acts as DJ, triggering sound effects on key events",
    "rules": [
      "ALL events use afplay for instant, non-blocking feedback",
      "Quick events (task/lesson/badge) use single sounds (< 2 seconds)",
      "Epic moments (module/level/class) use choreographed sound sequences (3-6 seconds)",
      "ALL music commands MUST use run_in_background: true in Bash tool",
      "Music must NEVER block teaching flow",
      "Random sequence selection for events with multiple sequences",
      "Sequences play multiple sounds with precise timing delays",
      "Error suppression: commands fail silently if sound files unavailable"
    ],
    "command_patterns": {
      "afplay_single": {
        "basic": "afplay /System/Library/Sounds/{sound}",
        "non_blocking": "(afplay /System/Library/Sounds/{sound} 2>/dev/null || true) &",
        "description": "Single sound playback with error suppression"
      },
      "afplay_sequence": {
        "pattern": "(afplay /System/Library/Sounds/{sound} 2>/dev/null || true) & (sleep {delay} && afplay /System/Library/Sounds/{sound2} 2>/dev/null || true) &",
        "description": "Multiple sounds with delays - all commands run simultaneously, delays control when each sound plays",
        "example": "(afplay /System/Library/Sounds/Hero.aiff 2>/dev/null || true) & (sleep 1.5 && afplay /System/Library/Sounds/Glass.aiff 2>/dev/null || true) & (sleep 3 && afplay /System/Library/Sounds/Sosumi.aiff 2>/dev/null || true) &"
      }
    },
    "sequence_execution_logic": {
      "description": "How to execute sound sequences",
      "steps": [
        "1. Read music_config.json for the event",
        "2. If event has 'sequences' array, pick random sequence",
        "3. If event has single 'sequence' object, use that",
        "4. Build command for each sound in sequence with its delay",
        "5. Execute all commands together (parallel with delays)",
        "6. Optional: Display sequence name to user"
      ],
      "timing": "All commands launch simultaneously. Sleep delays control when each sound plays. First sound plays instantly, subsequent sounds play after their delays."
    }
  }
}
